<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NCC Air Force Wing — Farewell</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800;900&family=Rajdhani:wght@300;400;500;600&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --sky: #0a0e1a;
    --sky-mid: #0d1530;
    --horizon: #0f2040;
    --gold: #c8a84b;
    --gold-light: #f0d080;
    --gold-dim: #6b5820;
    --silver: #8fa8c0;
    --silver-light: #c8ddf0;
    --accent: #4a9eff;
    --accent-glow: rgba(74, 158, 255, 0.3);
    --text: #e8f0f8;
    --text-dim: #7090b0;
    --danger: #ff4444;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--sky);
    color: var(--text);
    font-family: 'Rajdhani', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Stars background ── */
  .stars-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(1px 1px at 10% 15%, rgba(200,220,255,0.9) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 8%, rgba(200,220,255,0.7) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 40% 22%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 5%, rgba(200,220,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 18%, rgba(255,255,255,0.9) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 85% 10%, rgba(200,220,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 35%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 32% 42%, rgba(200,220,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 38%, rgba(255,255,255,0.7) 0%, transparent 100%),
      radial-gradient(1px 1px at 78% 30%, rgba(200,220,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 92% 45%, rgba(255,255,255,0.8) 0%, transparent 100%),
      radial-gradient(1px 1px at 5% 55%, rgba(200,220,255,0.4) 0%, transparent 100%),
      radial-gradient(2px 2px at 48% 58%, rgba(255,255,255,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 67% 65%, rgba(200,220,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 83% 70%, rgba(255,255,255,0.4) 0%, transparent 100%);
    background-size: 100% 100%;
  }

  /* ── Horizon glow ── */
  .horizon-glow {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: 300px;
    background: linear-gradient(to top,
      rgba(10, 40, 80, 0.6) 0%,
      rgba(10, 30, 60, 0.3) 50%,
      transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Scanline overlay ── */
  .scanlines {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
  }

  /* ── Header / Hero ── */
  header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 60px 20px 50px;
    border-bottom: 1px solid rgba(200, 168, 75, 0.2);
  }

  .emblem {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    margin-bottom: 24px;
    position: relative;
  }

  .emblem svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 0 16px rgba(200,168,75,0.6));
    animation: emblem-pulse 3s ease-in-out infinite;
  }

  @keyframes emblem-pulse {
    0%, 100% { filter: drop-shadow(0 0 12px rgba(200,168,75,0.5)); }
    50% { filter: drop-shadow(0 0 24px rgba(200,168,75,0.9)); }
  }

  .rank-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.8;
  }

  h1 {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 900;
    letter-spacing: 4px;
    color: #fff;
    text-shadow: 0 0 40px rgba(200,168,75,0.4);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  h1 span {
    color: var(--gold);
  }

  .subtitle {
    font-family: 'Rajdhani', sans-serif;
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 8px;
    color: var(--silver);
    text-transform: uppercase;
    margin-top: 12px;
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: center;
    margin: 24px auto;
    max-width: 400px;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold-dim), transparent);
  }

  .divider-diamond {
    width: 6px;
    height: 6px;
    background: var(--gold);
    transform: rotate(45deg);
  }

  /* ── HUD frame top ── */
  .hud-top {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 30px;
    background: rgba(10, 18, 40, 0.9);
    border-bottom: 1px solid rgba(74, 158, 255, 0.15);
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 2px;
  }

  .hud-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .hud-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.2; }
  }

  /* ── Main grid ── */
  main {
    position: relative;
    z-index: 10;
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 24px 80px;
  }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 5px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 40px;
    text-align: center;
    opacity: 0.7;
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  /* ── Option Card ── */
  .option-card {
    background: rgba(15, 25, 55, 0.85);
    border: 1px solid rgba(200,168,75,0.2);
    border-radius: 2px;
    padding: 0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
    text-decoration: none;
    display: block;
  }

  .option-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(200,168,75,0.05) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .option-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .option-card:hover {
    transform: translateY(-4px);
    border-color: rgba(200,168,75,0.5);
  }

  .option-card:hover::before,
  .option-card:hover::after { opacity: 1; }

  .card-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--gold-dim);
    border-style: solid;
    opacity: 0.5;
    transition: opacity 0.3s, border-color 0.3s;
  }

  .card-corner.tl { top: 8px; left: 8px; border-width: 1px 0 0 1px; }
  .card-corner.br { bottom: 8px; right: 8px; border-width: 0 1px 1px 0; }

  .option-card:hover .card-corner { opacity: 1; border-color: var(--gold); }

  .card-number {
    font-family: 'Orbitron', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--gold-dim);
    padding: 16px 20px 0;
    font-variant-numeric: tabular-nums;
  }

  .card-icon-wrap {
    padding: 20px 20px 0;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(200,168,75,0.25);
    border-radius: 2px;
    position: relative;
    flex-shrink: 0;
  }

  .card-icon svg { color: var(--gold); }

  .card-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--text);
    line-height: 1.3;
    text-transform: uppercase;
  }

  .card-body {
    padding: 16px 20px 24px;
  }

  .card-desc {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-dim);
    letter-spacing: 0.5px;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .card-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--gold);
    text-transform: uppercase;
    border: 1px solid rgba(200,168,75,0.3);
    padding: 8px 16px;
    border-radius: 1px;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .option-card:hover .card-action {
    background: rgba(200,168,75,0.1);
    border-color: rgba(200,168,75,0.6);
    color: var(--gold-light);
  }

  .card-action svg {
    width: 12px;
    height: 12px;
    transition: transform 0.2s;
  }

  .option-card:hover .card-action svg { transform: translateX(3px); }

  .tag-coming {
    display: inline-block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--accent);
    border: 1px solid rgba(74,158,255,0.3);
    padding: 2px 8px;
    border-radius: 1px;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  /* ── Venue Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5, 10, 25, 0.92);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: rgba(10, 18, 42, 0.98);
    border: 1px solid rgba(200,168,75,0.35);
    border-radius: 2px;
    max-width: 640px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: modal-in 0.3s ease;
  }

  @keyframes modal-in {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-header {
    padding: 24px 28px 20px;
    border-bottom: 1px solid rgba(200,168,75,0.15);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .modal-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--gold);
    text-transform: uppercase;
  }

  .modal-subtitle {
    font-size: 13px;
    color: var(--text-dim);
    margin-top: 4px;
    letter-spacing: 1px;
  }

  .modal-close {
    background: none;
    border: 1px solid rgba(200,168,75,0.2);
    color: var(--text-dim);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 1px;
    flex-shrink: 0;
    transition: border-color 0.2s, color 0.2s;
  }

  .modal-close:hover { border-color: var(--gold); color: var(--gold); }

  .modal-body { padding: 24px 28px 32px; }

  .venue-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .venue-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .venue-field.full { grid-column: 1 / -1; }

  .field-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--accent);
    text-transform: uppercase;
    opacity: 0.7;
  }

  .field-value {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.5px;
    line-height: 1.4;
    border-bottom: 1px solid rgba(200,168,75,0.1);
    padding-bottom: 8px;
  }

  .venue-note {
    background: rgba(200,168,75,0.05);
    border: 1px solid rgba(200,168,75,0.15);
    border-left: 3px solid var(--gold-dim);
    border-radius: 1px;
    padding: 12px 16px;
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.6;
    letter-spacing: 0.3px;
    font-style: italic;
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
  }

  .section-divider-line {
    flex: 1;
    height: 1px;
    background: rgba(200,168,75,0.12);
  }

  .section-divider-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 4px;
    color: var(--gold-dim);
    text-transform: uppercase;
  }

  /* Schedule rows */
  .schedule-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .schedule-time {
    font-family: 'Share Tech Mono', monospace;
    font-size: 12px;
    color: var(--gold);
    min-width: 80px;
    flex-shrink: 0;
  }

  .schedule-event {
    font-size: 14px;
    color: var(--text);
    letter-spacing: 0.3px;
  }

  .schedule-event small {
    font-size: 12px;
    color: var(--text-dim);
    display: block;
    margin-top: 2px;
  }

  /* ── Footer ── */
  footer {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 28px 20px;
    border-top: 1px solid rgba(200,168,75,0.1);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--text-dim);
    opacity: 0.5;
    text-transform: uppercase;
  }

  /* ── Plane decoration ── */
  .plane-deco {
    position: fixed;
    bottom: 80px;
    right: -60px;
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
    animation: plane-drift 20s ease-in-out infinite;
  }

  @keyframes plane-drift {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-20px) rotate(-3deg); }
  }

  @media (max-width: 640px) {
    .venue-grid { grid-template-columns: 1fr; }
    .hud-top { font-size: 9px; padding: 8px 14px; }
    h1 { letter-spacing: 2px; }
  }
</style>
</head>
<body>

<div class="stars-layer"></div>
<div class="horizon-glow"></div>
<div class="scanlines"></div>

<!-- Plane decoration -->
<div class="plane-deco">
  <svg width="500" height="200" viewBox="0 0 500 200" fill="white" xmlns="http://www.w3.org/2000/svg">
    <path d="M480 90 L80 50 L0 90 L80 130 Z"/>
    <path d="M200 50 L160 10 L140 50 Z"/>
    <path d="M200 130 L160 170 L140 130 Z"/>
    <path d="M80 90 L40 70 L30 90 L40 110 Z"/>
  </svg>
</div>

<!-- HUD top bar -->
<div class="hud-top">
  <div class="hud-item">
    <div class="hud-dot"></div>
    NCC AIR FORCE WING
  </div>
  <div class="hud-item">
    FAREWELL CEREMONY
  </div>
  <div class="hud-item">
    STATUS: ACTIVE
  </div>
</div>

<!-- Header -->
<header>
  <div class="emblem">
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="50" cy="50" r="44" stroke="#c8a84b" stroke-width="1.5" stroke-dasharray="4 3"/>
      <circle cx="50" cy="50" r="36" stroke="#c8a84b" stroke-width="0.5" opacity="0.4"/>
      <!-- Wings -->
      <path d="M50 50 L10 38 L18 50 L10 62 Z" fill="#c8a84b" opacity="0.9"/>
      <path d="M50 50 L90 38 L82 50 L90 62 Z" fill="#c8a84b" opacity="0.9"/>
      <!-- Body -->
      <ellipse cx="50" cy="50" rx="8" ry="14" fill="#c8a84b"/>
      <!-- Cockpit -->
      <ellipse cx="50" cy="42" rx="4" ry="5" fill="#0a0e1a" stroke="#c8a84b" stroke-width="0.5"/>
      <!-- Star top -->
      <polygon points="50,16 52,22 58,22 53,26 55,32 50,28 45,32 47,26 42,22 48,22" fill="#c8a84b" opacity="0.8"/>
    </svg>
  </div>

  <p class="rank-label">National Cadet Corps</p>
  <h1>AIR FORCE <span>WING</span></h1>
  <p class="subtitle">Farewell Ceremony</p>

  <div class="divider">
    <div class="divider-line"></div>
    <div class="divider-diamond"></div>
    <div class="divider-line"></div>
  </div>

  <p style="font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--silver);letter-spacing:3px;opacity:0.6;">
    "TOUCH THE SKY WITH GLORY"
  </p>
</header>

<!-- Main -->
<main>
  <p class="section-label">— Select Mission Briefing —</p>

  <div class="options-grid">

    <!-- Card 1: AV Video -->
    <div class="option-card" onclick="alert('The AV video will be available soon. Stay tuned!')">
      <div class="card-corner tl"></div>
      <div class="card-corner br"></div>
      <div class="card-number">01 / 03</div>
      <div class="card-icon-wrap">
        <div class="card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
            <polygon points="5,3 19,12 5,21" fill="currentColor" stroke="none" opacity="0.8"/>
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.2"/>
          </svg>
        </div>
        <div class="card-title">AV Video</div>
      </div>
      <div class="card-body">
        <div class="tag-coming">⬤ Uploading Soon</div>
        <p class="card-desc">Watch the official farewell audiovisual presentation — a tribute to every cadet's journey, memories, and wings earned in the Air Force Wing.</p>
        <span class="card-action">
          Watch Now
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </span>
      </div>
    </div>

    <!-- Card 2: Google Drive -->
    <a class="option-card" href="https://drive.google.com/drive/folders/1WLdBC2I-OJj4lJr9f02gjd97BaEbtWS3" target="_blank">
      <div class="card-corner tl"></div>
      <div class="card-corner br"></div>
      <div class="card-number">02 / 03</div>
      <div class="card-icon-wrap">
        <div class="card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 20h20L12 2z" stroke="currentColor" stroke-linejoin="round" opacity="0.3"/>
            <path d="M8.5 14L12 8l3.5 6H8.5z" fill="currentColor" opacity="0.7"/>
            <path d="M2 20l7-12" stroke="currentColor"/>
            <path d="M22 20l-7-12" stroke="currentColor"/>
            <path d="M2 20h20" stroke="currentColor"/>
          </svg>
        </div>
        <div class="card-title">Google Drive</div>
      </div>
      <div class="card-body">
        <div class="tag-coming">⬤ Drive ready</div>
        <p class="card-desc">Access the shared photo gallery, documents, and memories archive from the farewell events — all secured in the mission cloud drive.</p>
        <span class="card-action">
          Open Drive
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </span>
      </div>
    </div>

    <!-- Card 3: Venue Details -->
    <div class="option-card" onclick="document.getElementById('venueModal').classList.add('open')">
      <div class="card-corner tl"></div>
      <div class="card-corner br"></div>
      <div class="card-number">03 / 03</div>
      <div class="card-icon-wrap">
        <div class="card-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-linejoin="round"/>
            <circle cx="12" cy="9" r="2.5" fill="currentColor" opacity="0.7"/>
          </svg>
        </div>
        <div class="card-title">Venue Details</div>
      </div>
      <div class="card-body">
        <div class="tag-coming" style="color:var(--gold);border-color:rgba(200,168,75,0.4);">⬤ Briefing Ready</div>
        <p class="card-desc">Full mission briefing on the farewell venue — location, schedule, dress code, reporting time, and all event coordinates.</p>
        <span class="card-action">
